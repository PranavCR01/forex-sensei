# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Supabase — get these from your project's Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PIN lock — shown in browser bundle, intentional for single-user tool
VITE_APP_PIN=1234

# Server-side only (no VITE_ prefix — never sent to the browser)
# Groq: https://console.groq.com
GROQ_API_KEY=

# Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=

# OilPriceAPI — real-time WTI price (near-live, ~5min delay): https://oilpriceapi.com
OIL_PRICE_API_KEY=

# deprecated — switched to OilPriceAPI for real-time WTI
# EIA_API_KEY=
